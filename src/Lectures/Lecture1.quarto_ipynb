      "source": [
        "## Example problem: {auto-animate=\"true\" .smaller .scrollable}"
      ],
      "id": "8b1e02dd"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| echo: true\n",
        "from ipywidgets import interact, IntSlider\n",
        "@interact(n_elements=IntSlider(min=1, max=50, step=1, value=2, description='# Elements:'))\n",
        "def interactive_solver_plot(n_elements):\n",
        "    # This function is called whenever the slider changes\n",
        "    # It calls your original solver/plotter function\n",
        "    fig = fem.solve_specific_1d_problem_animated(n_elements)\n",
        "    # ipywidgets automatically displays the returned figure\n",
        "    return fig"
      ],
